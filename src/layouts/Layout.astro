---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "eigenwallet - The Monero wallet for the future" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/imgs/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Monerotopia Banner -->
    <div id="monerotopia-banner" class="bg-[#2d6b4f] text-white py-2 px-4 text-center relative font-sans hidden">
      <a href="https://monerotopia.com/" target="_blank" class="font-medium hover:underline text-[#f7a41d]">Meet us at Monerotopia 2026!</a>
      <button
        id="close-banner"
        class="absolute right-4 top-1/2 -translate-y-1/2 text-white hover:text-gray-300 transition-colors p-1 cursor-pointer"
        aria-label="Close banner"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"/>
        </svg>
      </button>
    </div>
    <script>
      const banner = document.getElementById('monerotopia-banner');
      const closeBtn = document.getElementById('close-banner');

      if (!localStorage.getItem('monerotopia-banner-closed')) {
        banner?.classList.remove('hidden');
      }

      closeBtn?.addEventListener('click', () => {
        banner?.classList.add('hidden');
        localStorage.setItem('monerotopia-banner-closed', 'true');
      });
    </script>

    <header class="flex flex-col mb-8 font-sans">
      <div class="bg-[#111111]">
        <div class="max-w-[1200px] mx-auto px-4 w-full">
          <a href="/" class="flex items-center gap-3 no-underline hover:opacity-90 transition-opacity py-4">
            <img src="/imgs/icon_new.svg" alt="eigenwallet" class="h-[60px] w-auto" />
          </a>
        </div>
      </div>
      
      <!-- Desktop Navigation -->
      <nav class="hidden md:block bg-[#737475] text-white border-t-4 border-[#f7a41d]">
        <div class="max-w-[1200px] mx-auto px-4 py-1 flex gap-6 text-[1.1rem] font-medium">
          <a href="/download" class="text-white hover:text-gray-200 transition-colors py-1 flex items-center gap-1.5">
            <img src="/icons/download.svg" width="16" height="16" alt="Download" />
            Download
          </a>
          <a href="/liquidity" class="text-white hover:text-gray-200 transition-colors py-1 flex items-center gap-1.5">
            <img src="/icons/liquidity.svg" width="16" height="16" alt="Liquidity" />
            Liquidity
          </a>
          <a href="/changelog" class="text-white hover:text-gray-200 transition-colors py-1 flex items-center gap-1.5">
            <img src="/icons/changelog.svg" width="16" height="16" alt="Changelog" />
            Changelog
          </a>
          <a href="/why" class="text-white hover:text-gray-200 transition-colors py-1 flex items-center gap-1.5">
            <img src="/icons/atomic-swaps.svg" width="16" height="16" alt="Atomic Swaps" />
            Why
          </a>
          <a href="https://docs.eigenwallet.org/" target="_blank" class="ml-auto text-white hover:text-gray-200 transition-colors py-1 flex items-center gap-1.5">
            <img src="/icons/docs.svg" width="16" height="16" alt="Docs" />
            Docs <span class="text-gray-400">(work in progress)</span>
          </a>
        </div>
      </nav>

      <!-- Mobile Navigation -->
      <nav class="md:hidden bg-[#737475] text-white border-t-4 border-[#f7a41d]">
        <label for="mobile-menu-toggle" class="block cursor-pointer">
          <div class="max-w-[1200px] mx-auto px-4 py-2 flex items-center justify-between">
            <span class="text-[1.1rem] font-medium text-gray-200">Menu</span>
            <div class="p-1">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z"/>
              </svg>
            </div>
          </div>
        </label>
      </nav>
      
      <!-- Mobile Menu (collapsible) -->
      <div class="md:hidden bg-[#535455]">
        <input type="checkbox" id="mobile-menu-toggle" class="hidden peer" />
        <div class="hidden peer-checked:block">
          <div class="max-w-[1200px] mx-auto px-4 py-2 flex flex-col text-[1.1rem] font-medium">
            <a href="/download" class="text-white hover:text-gray-200 transition-colors py-2 flex items-center gap-2">
              <img src="/icons/download.svg" width="16" height="16" alt="Download" />
              Download
            </a>
            <a href="/liquidity" class="text-white hover:text-gray-200 transition-colors py-2 flex items-center gap-2">
              <img src="/icons/liquidity.svg" width="16" height="16" alt="Liquidity" />
              Liquidity
            </a>
            <a href="/changelog" class="text-white hover:text-gray-200 transition-colors py-2 flex items-center gap-2">
              <img src="/icons/changelog.svg" width="16" height="16" alt="Changelog" />
              Changelog
            </a>
            <a href="/why" class="text-white hover:text-gray-200 transition-colors py-2 flex items-center gap-2">
              <img src="/icons/atomic-swaps.svg" width="16" height="16" alt="Why" />
              Why
            </a>
            <a href="https://docs.eigenwallet.org/" target="_blank" class="text-white hover:text-gray-200 transition-colors py-2 flex items-center gap-2">
              <img src="/icons/docs.svg" width="16" height="16" alt="Docs" />
              Docs
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1" style="max-width: 1200px; margin: 0 auto; padding: 0 1rem; width: 100%; box-sizing: border-box;">
      <slot />
    </main>

    <footer class="mt-auto py-8">
      <div class="flex justify-center">
        <div class="bg-[#e8e8e8] rounded-full px-8 py-3 flex gap-10">
          <a href="https://discord.gg/aqSyyJ35UW" target="_blank" class="opacity-60 hover:opacity-100 transition-opacity">
            <img src="/imgs/discord.svg" alt="Discord" class="h-6 w-6" />
          </a>
          <a href="https://x.com/eigenwallet" target="_blank" class="opacity-60 hover:opacity-100 transition-opacity">
            <img src="/imgs/x.svg" alt="X" class="h-6 w-6" />
          </a>
          <a href="https://matrix.to/#/%23unstoppableswap-space:matrix.org" target="_blank" class="opacity-60 hover:opacity-100 transition-opacity">
            <img src="/imgs/matrix.svg" alt="Matrix" class="h-6 w-6" />
          </a>
          <a href="https://github.com/eigenwallet/core" target="_blank" class="opacity-60 hover:opacity-100 transition-opacity">
            <img src="/imgs/github.svg" alt="GitHub" class="h-6 w-6" />
          </a>
          <a href="http://eigenwu5vl53rjyd3zxfzy25mfoaeqlhpuvlu5s46ygggllfbb4beiid.onion/" target="_blank" class="opacity-60 hover:opacity-100 transition-opacity">
            <img src="/imgs/tor.svg" alt="Tor" class="h-6 w-6" />
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
